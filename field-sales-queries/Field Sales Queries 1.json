      {
        "type": "code",
        "data": {
          "executionId": null,
          "errorHandling": {
            "strategy": "stop"
          },
          "disabled": false,
          "name": "Code",
          "slug": "code",
          "language": "javascript",
          "code": "function extractSlackListData(payload) {\n  const attachment = payload.attachments?.[0];\n  const fields = attachment?.list_record?.record?.fields || [];\n  const schema = attachment?.list_record?.schema || [];\n\n  const result = {};\n\n  fields.forEach(field => {\n    const schemaItem = schema.find(s => s.key === field.key);\n    if (!schemaItem) return;\n\n    const name = schemaItem.name.toLowerCase().replace(/\\s+/g, \"_\");\n\n    if (field.text) {\n      result[name] = field.text;\n    } else if (field.value && schemaItem.options?.choices) {\n      const choice = schemaItem.options.choices.find(c => c.value === field.value);\n      result[name] = choice ? choice.label : field.value;\n    } else if (field.user) {\n      result[name] = field.user[0];\n    } else if (field.timestamp) {\n      result[name] = new Date(field.timestamp[0] * 1000).toISOString();\n    } else if (field.checkbox !== undefined) {\n      result[name] = field.checkbox;\n    }\n  });\n\n  const text = payload.text || \"\";\n  const mentionMatch = text.match(/^@([^\\(]+)\\s*\\(/);\n  if (mentionMatch) {\n    result.submitted_by_name = mentionMatch[1].trim();\n  }\n\n  return result;\n}\n\nreturn extractSlackListData(newMessageInChannel.output);"
        },
