          "code": "const status = jiraUpdatedIssue.output.status || '';\nconst summary = (jiraUpdatedIssue.output.summary || '').toLowerCase();\n\nreturn {\n  isDone: status === 'Done' || status === 'Closed',\n  hasSalesQuery: summary.includes('field-sales-queries'),\n  matches: (status === 'Done' || status === 'Closed') && summary.includes('field-sales-queries')\n};"
