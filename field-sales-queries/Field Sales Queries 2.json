          "disabled": false,
          "name": "Find matching row for Jira ticket",
          "slug": "findMatchingRow",
          "language": "javascript",
          "code": "const issueKey = (jiraUpdatedIssue.output.key || '').toString().trim();\nconst issueSummary = (jiraUpdatedIssue.output.summary || '').toString().trim();\n\n// The Google Sheets action returns data under output.values as a 2D array\nconst rows = getSheetRows.output.values || getSheetRows.output.rows || [];\n\nlet matchedRow = null;\nlet rowIndex = -1;\n\nfor (let i = 0; i < rows.length; i++) {\n  const cells = rows[i];\n\n  if (!Array.isArray(cells)) continue;\n\n  // Match if any cell equals the Jira issue key (e.g. WOR-15608)\n  const match = cells.some(v => {\n    const cell = (v ?? '').toString().trim();\n    return cell === issueKey || cell === issueSummary;\n  });\n\n  if (match) {\n    matchedRow = cells;\n    rowIndex = i;\n    break;\n  }\n}\n\nreturn {\n  found: matchedRow !== null,\n  rowIndex,\n  // +2 because sheets are 1-indexed and we need to account for a potential header row offset\n  sheetRowIndex: rowIndex + 1,\n  row: matchedRow,\n  issueKey,\n  issueSummary,\n  channelId: matchedRow ? (matchedRow[2] || null) : null,\n  threadTs: matchedRow ? (matchedRow[1] || null) : null\n};"
        },
        "id": "1160f16d-e1c2-4822-a686-ad049a2601ca",
        "position": {
